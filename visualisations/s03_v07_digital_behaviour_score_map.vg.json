{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "State Digital Behaviour Choropleth, 2025",
    "subtitle": "District polygons provide geographic detail, while colour represents each state's digital behaviour score; darker areas indicate stronger digital behaviour.",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "color": "#0f172a",
    "subtitleColor": "#475569"
  },
  "width": 760,
  "height": 480,
  "projection": {
    "type": "mercator",
    "center": [109.69, 3.95],
    "scale": 2000,
    "translate": [450, 320]
  },
  "layer": [
    {
      "data": {
        "url": "../data/05_malaysia_districts_coloured_by_state_score_vl_ready.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "properties.digital_behaviour_score",
          "type": "quantitative",
          "title": "State digital behaviour score",
          "scale": {
            "domain": [55, 77],
            "range": ["#e0f2fe", "#7dd3fc", "#2563eb", "#0f172a"]
          },
          "legend": {
            "orient": "bottom",
            "gradientLength": 280
          }
        },
        "tooltip": [
          { "field": "properties.district",                   "type": "nominal",      "title": "District" },
          { "field": "properties.state",                      "type": "nominal",      "title": "State" },
          { "field": "properties.region_group",               "type": "nominal",      "title": "Region" },
          { "field": "properties.digital_behaviour_score",    "type": "quantitative", "title": "State digital behaviour score", "format": ".1f" },
          { "field": "properties.dominant_digital_behaviour", "type": "nominal",      "title": "Dominant behaviour" },
          { "field": "properties.population_million",         "type": "quantitative", "title": "Population (million)",          "format": ".2f" }
        ]
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": { "stroke": null },
    "legend": {
      "labelFontSize": 11,
      "titleFontSize": 12,
      "labelColor": "#475569",
      "titleColor": "#334155"
    }
  }
}